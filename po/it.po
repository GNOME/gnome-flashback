#: data/schemas/org.gnome.gnome-flashback.gschema.xml:5
msgid "a11y-keyboard"
msgstr "a11y-keyboard"

#: data/schemas/org.gnome.gnome-flashback.gschema.xml:10
msgid "Audio device selection"
msgstr "Selezione dispositivo audio"

#: data/schemas/org.gnome.gnome-flashback.gschema.xml:11
msgid ""
"If set to true, then GNOME Flashback application will be used to provide the audio "
"device selection dialog."
msgstr ""
"Se impostata su vero, l'applicazione GNOME Flashback sarà usata per fornire il "
"dialogo della selezione del dispositivo audio."

#: data/schemas/org.gnome.gnome-flashback.gschema.xml:16
msgid "Automount manager"
msgstr "Gestore montaggio automatico"

#: data/schemas/org.gnome.gnome-flashback.gschema.xml:17
msgid ""
"If set to true, then GNOME Flashback application will be used to automount removable "
"media."
msgstr ""
"Se impostata su vero, l'applicazione GNOME Flashback sarà usata per montare "
"automaticamente i dispositivi rimovibili."

#: data/schemas/org.gnome.gnome-flashback.gschema.xml:22
#: gnome-flashback/libdesktop/gf-desktop-window.c:824
msgid "Desktop"
msgstr "Scrivania"

#: data/schemas/org.gnome.gnome-flashback.gschema.xml:27
msgid "End session dialog"
msgstr "Dialogo termina sessione"

#: data/schemas/org.gnome.gnome-flashback.gschema.xml:28
msgid ""
"If set to true, then GNOME Flashback application will be used to show the end session "
"dialog."
msgstr ""
"Se impostata su vero, l'applicazione GNOME Flashback sarà usata per mostrare il "
"dialogo del termina sessione."

#: data/schemas/org.gnome.gnome-flashback.gschema.xml:33
msgid "Input settings"
msgstr "Impostazioni di input"

#: data/schemas/org.gnome.gnome-flashback.gschema.xml:38
msgid "Keyboard layouts and input methods"
msgstr "Disposizioni della tastiera e metodi di input"

#: data/schemas/org.gnome.gnome-flashback.gschema.xml:39
msgid ""
"If set to true, then GNOME Flashback application will be used to manage keyboard "
"layouts and input methods."
msgstr ""
"Se impostata su vero, l'applicazione GNOME Flashback sarà usata per gestire le "
"disposizioni della tastiera e i metodi di input."

#: data/schemas/org.gnome.gnome-flashback.gschema.xml:44
msgid "Notification daemon"
msgstr "Demone di notifica"

#: data/schemas/org.gnome.gnome-flashback.gschema.xml:45
msgid ""
"If set to true, then GNOME Flashback application will be used to manage notifications."
msgstr ""
"Se impostata su vero, l'applicazione GNOME Flashback sarà usata per gestire le "
"notifiche."

#: data/schemas/org.gnome.gnome-flashback.gschema.xml:50
msgid "Root background"
msgstr "Sfondo principale"

#: data/schemas/org.gnome.gnome-flashback.gschema.xml:55
msgid "Screencasts"
msgstr "Registrare la scrivania"

#: data/schemas/org.gnome.gnome-flashback.gschema.xml:56
msgid ""
"If set to true, then GNOME Flashback application will be used to record the screen."
msgstr ""
"Se impostata su vero, l'applicazione GNOME Flashback sarà usata per registrare la "
"scrivania."

#: data/schemas/org.gnome.gnome-flashback.gschema.xml:61
msgid "Screensaver"
msgstr "Salvaschermo"

#: data/schemas/org.gnome.gnome-flashback.gschema.xml:62
msgid "If set to true, then GNOME Flashback application will be used as a screensaver."
msgstr ""
"Se impostata su vero, l'applicazione GNOME Flashback sarà usata come un salvaschermo."

#: data/schemas/org.gnome.gnome-flashback.gschema.xml:68
msgid ""
"If set to true, then GNOME Flashback application will be used to take screenshots."
msgstr ""
"Se impostata su vero, l'applicazione GNOME Flashback sarà usata per catturare una "
"schermata."

#: data/schemas/org.gnome.gnome-flashback.gschema.xml:73
msgid "Shell"
msgstr "Shell"

#: data/schemas/org.gnome.gnome-flashback.gschema.xml:74
msgid "If set to true, then GNOME Flashback application will be used as a shell."
msgstr "Se impostata su vero, l'applicazione GNOME Flashback sarà usata come una shell."

#: data/schemas/org.gnome.gnome-flashback.gschema.xml:79
msgid "Status Notifier Watcher"
msgstr "Notificatore controllo dello stato"

#: data/schemas/org.gnome.gnome-flashback.gschema.xml:80
msgid ""
"If set to true, then GNOME Flashback application will be used as Status Notifier "
"Watcher."
msgstr ""
"Se impostata su vero, l'applicazione GNOME Flashback sarà usata come Notificatore "
"controllo dello stato."

#: data/schemas/org.gnome.gnome-flashback.desktop.gschema.xml:5
msgid "Draw desktop background"
msgstr "Disegna lo sfondo della scrivania"

#: data/schemas/org.gnome.gnome-flashback.desktop.gschema.xml:6
msgid "If set to true, then GNOME Flashback will draw the desktop background."
msgstr "Se impostata su vero, GNOME Flashback disegnerà lo sfondo della scrivania."

#: data/schemas/org.gnome.gnome-flashback.desktop.gschema.xml:11
msgid "Show desktop icons"
msgstr "Mostra le icone sulla scrivania"

#: data/schemas/org.gnome.gnome-flashback.desktop.gschema.xml:12
msgid "If set to true, then GNOME Flashback will draw the icons on the desktop."
msgstr "Se impostata su vero, GNOME Flashback disegnerà le icone sulla scrivania."

#: data/schemas/org.gnome.gnome-flashback.desktop.background.gschema.xml:5
msgid "Fade the background on change"
msgstr "Sfondo in dissolvenza quando cambia"

#: data/schemas/org.gnome.gnome-flashback.desktop.background.gschema.xml:6
msgid "If set to true, then fade effect will be used to change the desktop background."
msgstr ""
"Se impostata su vero, l'effetto di dissolvenza sarà usato per cambiare lo sfondo alla "
"scrivania."

#: data/schemas/org.gnome.gnome-flashback.desktop.icons.gschema.xml:5
msgid "Icon size"
msgstr "Dimensione icone"

#: data/schemas/org.gnome.gnome-flashback.desktop.icons.gschema.xml:6
msgid "The size of desktop icons."
msgstr "La dimensione delle icone sulla scrivania."

#: data/schemas/org.gnome.gnome-flashback.desktop.icons.gschema.xml:11
#: gnome-flashback/libdesktop/gf-icon-view.c:1345
msgid "Placement"
msgstr "Posizionamento"

#: data/schemas/org.gnome.gnome-flashback.desktop.icons.gschema.xml:12
msgid ""
"Can be one of \"auto-arrange-icons\", \"align-icons-to-grid\" or \"free\". It "
"controls how icons are placed on desktop."
msgstr ""
"Può essere uno tra «auto-arrange-icons» (disposizione automatica), «align-icons-to-"
"grid» (allinea icone alla griglia) o «free» (libero). Controlla come le icone sono "
"posizionate sulla scrivania."

#: data/schemas/org.gnome.gnome-flashback.desktop.icons.gschema.xml:17
#: gnome-flashback/libdesktop/gf-icon-view.c:1351
msgid "Sort by"
msgstr "Ordina per"

#: data/schemas/org.gnome.gnome-flashback.desktop.icons.gschema.xml:18
msgid ""
"Can be one of \"name\", \"date-modified\" or \"size\". It controls how icons are "
"sorted in \"auto-arrange-icons\" placement."
msgstr ""
"Può essere uno tra «name» (nome), «date-modified» (data di modifica) o «size» "
"(dimensione). Controlla come le icone sono ordinate nel posizionamento «auto-arrange-"
"icons»."

#: data/schemas/org.gnome.gnome-flashback.desktop.icons.gschema.xml:24
msgid "Extra text width"
msgstr "Larghezza extra del testo"

#: data/schemas/org.gnome.gnome-flashback.desktop.icons.gschema.xml:25
msgid "Extra width for icon text."
msgstr "Larghezza extra per il testo dell'icona."

#: data/schemas/org.gnome.gnome-flashback.desktop.icons.gschema.xml:31
msgid "Column spacing"
msgstr "Spaziatura colonne"

#: data/schemas/org.gnome.gnome-flashback.desktop.icons.gschema.xml:32
msgid "The amount of space between columns."
msgstr "La quantità di spazio tra le colonne."

#: data/schemas/org.gnome.gnome-flashback.desktop.icons.gschema.xml:38
msgid "Row spacing"
msgstr "Spaziatura righe"

#: data/schemas/org.gnome.gnome-flashback.desktop.icons.gschema.xml:39
msgid "The amount of space between rows."
msgstr "La quantità di spazio tra le righe."

#: data/schemas/org.gnome.gnome-flashback.desktop.icons.gschema.xml:44
msgid "Show home icon"
msgstr "Mostra l'icona della home"

#: data/schemas/org.gnome.gnome-flashback.desktop.icons.gschema.xml:45
msgid ""
"If this is set to true, an icon linking to the home folder will be put on the desktop."
msgstr ""
"Se impostata su vero, un'icona che punta alla cartella home verrà inserita sulla "
"scrivania."

#: data/schemas/org.gnome.gnome-flashback.desktop.icons.gschema.xml:50
msgid "Show trash icon"
msgstr "Mostra l'icona del cestino"

#: data/schemas/org.gnome.gnome-flashback.desktop.icons.gschema.xml:51
msgid "If this is set to true, an icon linking to the trash will be put on the desktop."
msgstr ""
"Se impostata su vero, un'icona che punta al cestino verrà inserita sulla scrivania."

#: data/schemas/org.gnome.gnome-flashback.keybindings.gschema.xml:5
msgid "Take a screenshot"
msgstr "Cattura una schermata"

#: data/schemas/org.gnome.gnome-flashback.keybindings.gschema.xml:6
msgid "Binding to take a screenshot."
msgstr "Scorciatoia per catturare una schermata."

#: data/schemas/org.gnome.gnome-flashback.keybindings.gschema.xml:11
msgid "Take a screenshot of a window"
msgstr "Cattura una schermata di una finestra"

#: data/schemas/org.gnome.gnome-flashback.keybindings.gschema.xml:12
msgid "Binding to take a screenshot of a window."
msgstr "Scorciatoia per catturare una schermata di una finestra."

#: data/schemas/org.gnome.gnome-flashback.keybindings.gschema.xml:17
msgid "Take a screenshot of an area"
msgstr "Cattura una schermata di un'area"

#: data/schemas/org.gnome.gnome-flashback.keybindings.gschema.xml:18
msgid "Binding to take a screenshot of an area."
msgstr "Scorciatoia per catturare una schermata di un'area."

#: data/schemas/org.gnome.gnome-flashback.keybindings.gschema.xml:24
msgid "Binding to copy a screenshot to clipboard."
msgstr "Scorciatoia per copiare una schermata negli appunti."

#: data/schemas/org.gnome.gnome-flashback.keybindings.gschema.xml:30
msgid "Binding to copy a screenshot of a window to clipboard."
msgstr "Scorciatoia per copiare una schermata di una finestra negli appunti."

#: data/schemas/org.gnome.gnome-flashback.keybindings.gschema.xml:36
msgid "Binding to copy a screenshot of an area to clipboard."
msgstr "Scorciatoia per copiare una schermata di un'area negli appunti."

#: data/schemas/org.gnome.gnome-flashback.keybindings.gschema.xml:41
msgid "Record a short video of the screen"
msgstr "Registra un breve video dello schermo"

#: data/schemas/org.gnome.gnome-flashback.keybindings.gschema.xml:42
msgid "Binding to record a short video of the screen"
msgstr "Scorciatoia per registrare un breve video dello schermo"

#: data/schemas/org.gnome.gnome-flashback.keybindings.gschema.xml:47
msgid "Maximum length of screen recordings"
msgstr "Lunghezza massima delle registrazioni dello schermo"

#: data/schemas/org.gnome.gnome-flashback.keybindings.gschema.xml:48
msgid ""
"The maximum length of single screen cast recordings in seconds or 0 for unlimited"
msgstr ""
"La lunghezza massima delle singole registrazioni dello schermo in secondi o 0 per "
"illimitata"

#: data/schemas/org.gnome.gnome-flashback.notifications.gschema.xml:12
msgid "Location of the notifications"
msgstr "Posizione delle notifiche"

#: data/schemas/org.gnome.gnome-flashback.notifications.gschema.xml:13
msgid "The corner of the screen where notifications will be shown."
msgstr "L'angolo dello schermo dove verranno mostrate le notifiche."

#: data/schemas/org.gnome.gnome-flashback.system-indicators.input-sources.gschema.xml:5
msgid "Use IBus icon if available"
msgstr "Usa l'icona IBus se disponibile"

#: data/schemas/org.gnome.gnome-flashback.system-indicators.input-sources.gschema.xml:10
msgid "Icon background color"
msgstr "Colore di sfondo dell'icona"

#: data/schemas/org.gnome.gnome-flashback.system-indicators.input-sources.gschema.xml:15
msgid "Icon foreground color"
msgstr "Colore di primo piano dell'icona"

#: data/schemas/org.gnome.gnome-flashback.system-indicators.input-sources.gschema.xml:20
msgid "Icon font family"
msgstr "Famiglia del carattere dell'icona"

#: data/schemas/org.gnome.gnome-flashback.system-indicators.input-sources.gschema.xml:26
msgid "Icon font weight"
msgstr "Peso del carattere dell'icona"

#: data/ui/gf-confirm-display-change-dialog.ui:57
msgid "Do you want to keep these display settings?"
msgstr "Mantenere questa impostazioni di visualizzazione?"

#: data/ui/gf-confirm-display-change-dialog.ui:103
